---
import { Image } from "astro:assets";

const { product } = Astro.props;
const images = [product.data.mainImage, ...product.data.gallery];
const alt = [product.data.mainImageAlt, ...product.data.galleryAlt];
---

<div class="image-gallery">
  <Image class="gallery-main" src={images[0]} alt={alt[0]} width={960} height={720} loading="eager" />
  {images.length > 1 && (
    <div class="gallery-thumbs">
      {images.slice(1).map((image, index) => (
        <Image src={image} alt={alt[index + 1] || ""} width={320} height={240} loading="lazy" />
      ))}
    </div>
  )}
</div>
