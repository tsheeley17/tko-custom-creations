---
import type { CollectionEntry } from "astro:content";

const { categories } = Astro.props as { categories: CollectionEntry<"categories">[] };
---

<form class="filters" data-product-filters>
  <label class="search-field">
    <span>Search products</span>
    <input type="search" name="search" placeholder="Search by name, material, or tag" autocomplete="off" />
  </label>
  <label>
    <span>Category</span>
    <select name="category">
      <option value="">All categories</option>
      {categories.map((category) => <option value={category.data.slug}>{category.data.name}</option>)}
    </select>
  </label>
  <label>
    <span>Sort</span>
    <select name="sort">
      <option value="featured">Featured</option>
      <option value="name">Name</option>
      <option value="newest">Newest</option>
      <option value="price-asc">Price: Low to High</option>
      <option value="price-desc">Price: High to Low</option>
    </select>
  </label>
  <fieldset>
    <legend>Filters</legend>
    <label><input type="checkbox" name="featured" /> Featured</label>
    <label><input type="checkbox" name="customizable" /> Customizable</label>
    <label><input type="checkbox" name="newProduct" /> New</label>
  </fieldset>
  <p class="product-count" aria-live="polite"><span data-product-count>0</span> products</p>
</form>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-product-filters]");
  const grid = document.querySelector<HTMLElement>("[data-product-grid]");
  const count = document.querySelector<HTMLElement>("[data-product-count]");
  const empty = document.querySelector<HTMLElement>("[data-empty-state]");
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-product-card]"));

  function applyFilters() {
    if (!form || !grid) return;
    const data = new FormData(form);
    const query = String(data.get("search") || "").trim().toLowerCase();
    const category = String(data.get("category") || "");
    const featured = data.get("featured") === "on";
    const customizable = data.get("customizable") === "on";
    const newProduct = data.get("newProduct") === "on";
    const sort = String(data.get("sort") || "featured");

    const visible = cards.filter((card) => {
      const text = `${card.dataset.name || ""} ${card.textContent || ""}`.toLowerCase();
      return (
        (!query || text.includes(query)) &&
        (!category || card.dataset.category === category) &&
        (!featured || card.dataset.featured === "true") &&
        (!customizable || card.dataset.customizable === "true") &&
        (!newProduct || card.dataset.new === "true")
      );
    });

    const sorted = visible.toSorted((a, b) => {
      if (sort === "name") return (a.dataset.name || "").localeCompare(b.dataset.name || "");
      if (sort === "newest") return Date.parse(b.dataset.date || "") - Date.parse(a.dataset.date || "");
      if (sort === "price-asc") return safePrice(a) - safePrice(b);
      if (sort === "price-desc") return safePrice(b) - safePrice(a);
      return Number(b.dataset.featured === "true") - Number(a.dataset.featured === "true");
    });

    cards.forEach((card) => {
      card.hidden = !visible.includes(card);
    });
    sorted.forEach((card) => grid.append(card));
    if (count) count.textContent = String(visible.length);
    if (empty) empty.hidden = visible.length > 0;
  }

  function safePrice(card: HTMLElement) {
    const price = Number(card.dataset.price);
    return Number.isFinite(price) ? price : Number.MAX_SAFE_INTEGER;
  }

  function hydrateFromUrl() {
    if (!form) return;
    const params = new URLSearchParams(window.location.search);
    const category = params.get("category");
    if (category) {
      const input = form.elements.namedItem("category") as HTMLSelectElement | null;
      if (input) input.value = category;
    }
  }

  hydrateFromUrl();
  applyFilters();
  form?.addEventListener("input", applyFilters);
  form?.addEventListener("change", applyFilters);
</script>
