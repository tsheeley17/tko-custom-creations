---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy | TKO Custom Creations" description="General website privacy information for TKO Custom Creations.">
  <section class="page-hero compact">
    <div class="container">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy Information</h1>
      <p>This is general website copy and not legal advice.</p>
    </div>
  </section>
  <section class="section">
    <div class="container narrow prose">
      <p>This site does not directly process orders, payments, or payment information. Checkout occurs on Etsy, and Etsy has its own privacy, payment, shipping, and order policies.</p>
      <p>Basic website analytics may be used in the future if enabled. No analytics are added by default in this first version.</p>
      <p>Clicking external links sends visitors to another website. Customers who contact the business voluntarily provide the information included in that message or email.</p>
      <p>For questions about an Etsy order, use Etsy’s messaging and order tools so the conversation remains connected to the order record.</p>
    </div>
  </section>
</BaseLayout>
